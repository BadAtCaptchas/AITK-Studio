# syntax=docker/dockerfile:1
FROM nvidia/cuda:13.2.1-cudnn-devel-ubuntu24.04

ARG AITK_VERSION=0.9.10
ARG GIT_COMMIT=unknown

LABEL authors="jaret" \
    org.opencontainers.image.title="AI Toolkit RunPod Blackwell" \
    org.opencontainers.image.description="RunPod Pod image for OstrisAI-Toolkit Revamped UI with CUDA 13 and cu130 PyTorch." \
    org.opencontainers.image.source="https://github.com/BadAtCaptchas/ai-toolkit" \
    org.opencontainers.image.version="${AITK_VERSION}" \
    org.opencontainers.image.revision="${GIT_COMMIT}"

ENV DEBIAN_FRONTEND=noninteractive \
    TORCH_CUDA_ARCH_LIST="8.0 8.6 8.9 9.0 10.0 12.0" \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONIOENCODING=utf-8 \
    HF_HUB_ENABLE_HF_TRANSFER=1

RUN apt-get update && apt-get install --no-install-recommends -y \
    bash \
    ca-certificates \
    git \
    curl \
    build-essential \
    cmake \
    wget \
    python3.12 \
    python3-pip \
    python3-dev \
    python3-setuptools \
    python3-wheel \
    python3-venv \
    ffmpeg \
    tmux \
    htop \
    nvtop \
    python3-opencv \
    openssh-client \
    openssh-server \
    openssl \
    rsync \
    unzip \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /tmp
RUN curl -fsSL https://deb.nodesource.com/setup_23.x -o nodesource_setup.sh \
    && bash nodesource_setup.sh \
    && apt-get update \
    && apt-get install --no-install-recommends -y nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/nodesource_setup.sh

RUN curl -fsSL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb -o /tmp/cloudflared.deb \
    && apt-get update \
    && apt-get install --no-install-recommends -y /tmp/cloudflared.deb \
    && rm -f /tmp/cloudflared.deb \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://ollama.com/install.sh | sh

RUN ln -sf /usr/bin/python3 /usr/bin/python \
    && ln -sf /usr/bin/pip3 /usr/bin/pip

WORKDIR /app/ai-toolkit

COPY requirements_torch_blackwell_cu130.txt requirements_base.txt requirements.txt ./
RUN python -m pip install --no-cache-dir --break-system-packages -r requirements_torch_blackwell_cu130.txt \
    && python -m pip install --no-cache-dir --break-system-packages -r requirements.txt \
    && python -m pip install --no-cache-dir --break-system-packages setuptools==70.0.0

COPY ui/package.json ui/package-lock.json ./ui/
WORKDIR /app/ai-toolkit/ui
RUN npm ci

WORKDIR /app/ai-toolkit
COPY . .

WORKDIR /app/ai-toolkit/ui
RUN npm run update_db \
    && npm run build \
    && rm -f /app/ai-toolkit/aitk_db.db /app/ai-toolkit/aitk_db.db-shm /app/ai-toolkit/aitk_db.db-wal \
    && npm cache clean --force

EXPOSE 8675 6006 22

WORKDIR /
COPY docker/start-runpod.sh /start-runpod.sh
RUN chmod +x /start-runpod.sh

CMD ["/start-runpod.sh"]
