{
  "name": "aitk-studio-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run update_db && node scripts/run-app.mjs --mode dev",
    "build": "node scripts/clean-worker.mjs && node node_modules/typescript/bin/tsc -p tsconfig.worker.json && next build",
    "build:fast": "node scripts/clean-worker.mjs && node node_modules/typescript/bin/tsc -p tsconfig.worker.json && next build --experimental-app-only",
    "start": "npm run update_db && node scripts/run-app.mjs --mode start",
    "build_and_start": "npm install && npm run update_db && npm run build && npm run start",
    "sync:local": "node scripts/sync-local-changes.mjs",
    "lint": "next lint",
    "update_db": "node scripts/prepare-db.mjs",
    "test:metrics": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/metricsDownsample.test.mjs",
    "test:advisor": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/trainingAdvisor.test.mjs",
    "test:authenlora": "node --test scripts/authenloraConfig.test.mjs",
    "test:flux-guidance": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/fluxGuidancePolicy.test.mjs",
    "test:tensorboard": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/tensorboardConfig.test.mjs",
    "test:ltx-training": "node --test scripts/ltxTrainingOptions.test.mjs",
    "test:remote": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/cloudflaredConfig.test.mjs scripts/remoteClient.test.mjs scripts/jobsApiList.test.mjs scripts/queueSync.test.mjs scripts/openRouterPricing.test.mjs",
    "test:queue-reorder": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/queueReorder.test.mjs",
    "test:projects": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/projects.test.mjs",
    "test:lifecycle": "node --test scripts/appLifecycle.test.mjs",
    "test:basic": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/basicUtils.test.mjs scripts/pathContainment.test.mjs",
    "test:random-prompt": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/randomPromptCaptions.test.mjs",
    "test:dataset-combine": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/datasetCombine.test.mjs",
    "test:dataset-rename": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/datasetRename.test.mjs",
    "test:dataset-navigator": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/datasetImageNavigator.test.mjs",
    "test:dataset-watchers": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/datasetWatchers.test.mjs",
    "test:caption-bulk": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/captionKeywordSearch.test.mjs scripts/datasetCaptionBulk.test.mjs scripts/datasetRefusalCaptionAudit.test.mjs",
    "test:image-delete": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/imageDelete.test.mjs",
    "test:folder-import": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/folderImport.test.mjs",
    "test:hf-dataset-import": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/hfDatasetImport.test.mjs",
    "test:annotation-geometry": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/annotationGeometry.test.mjs",
    "test:ideogram-caption": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/ideogramCaption.test.mjs",
    "test:ideogram-workflow": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/ideogramWorkflow.test.mjs",
    "test:job-datasets": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/jobDatasetDefaults.test.mjs scripts/remoteDatasetRefs.test.mjs scripts/remoteDatasetSync.test.mjs scripts/remoteStartProgress.test.mjs scripts/remoteClientUpload.test.mjs scripts/remoteJobMissing.test.mjs",
    "test:openrouter-boxes": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/openRouterBoxes.test.mjs",
    "test:openrouter-layer-caption": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/openRouterLayerCaption.test.mjs",
    "test:encrypted-dataset-secrets": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/encryptedDatasetSecrets.test.mjs scripts/encryptedDatasets.test.mjs",
    "test:secure-caption": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/secureCaptionCrypto.test.mjs scripts/ollamaClient.test.mjs scripts/ollamaVision.test.mjs scripts/secureRemoteCaptionJobs.test.mjs scripts/remoteOllamaWorkers.test.mjs scripts/remoteCaptionJobs.test.mjs scripts/remoteCaptionResults.test.mjs",
    "test:phase-summary": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/trainingPhaseSummary.test.mjs",
    "test:lora-library": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/loraLibrary.test.mjs",
    "test:scripts": "node node_modules/typescript/bin/tsc -p tsconfig.worker.json && node --test scripts/scriptRunner.test.mjs",
    "migrate_sqlite_to_mongo": "node scripts/migrate-sqlite-to-mongo.mjs",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,scss}\""
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "classnames": "^2.5.1",
    "lucide-react": "^0.475.0",
    "mongodb": "^6.20.0",
    "next": "^15.5.9",
    "node-cache": "^5.1.2",
    "prisma": "^7.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.5",
    "react-global-hooks": "^1.3.5",
    "react-icons": "^5.5.0",
    "react-select": "^5.10.1",
    "react-virtuoso": "^4.18.7",
    "react-zoom-pan-pinch": "^4.0.3",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.27.11",
    "uplot": "^1.6.32",
    "uuid": "^11.1.0",
    "yaml": "^2.7.0",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/yauzl": "^2.10.3",
    "concurrently": "^9.1.2",
    "postcss": "^8",
    "prettier": "^3.5.1",
    "prettier-basic": "^1.0.0",
    "tailwindcss": "^3.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "macstats": "^4.2.0"
  },
  "prettier": "prettier-basic"
}
