generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Queue {
  id         Int     @id @default(autoincrement())
  worker_id  String  @default("local")
  gpu_ids    String
  is_running Boolean @default(false)

  @@unique([worker_id, gpu_ids])
  @@index([worker_id])
  @@index([gpu_ids])
}

model WorkerNode {
  id              String   @id @default(uuid())
  name            String   @unique
  base_url        String
  api_token       String
  enabled         Boolean  @default(true)
  last_status     String   @default("unknown")
  last_error      String?
  last_checked_at DateTime?
  capabilities    String   @default("{}") // JSON string
  gpus            String   @default("[]") // JSON string
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([enabled])
}

model Job {
  id              String   @id @default(uuid())
  name            String   @unique
  worker_id       String   @default("local")
  remote_job_id   String?
  remote_sync_at  DateTime?
  remote_error    String?
  gpu_ids         String
  job_config      String // JSON string
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  status          String   @default("stopped")
  stop            Boolean  @default(false)
  return_to_queue Boolean  @default(false) // same as stop, but will be set to 'queued' when stopped
  step            Int      @default(0)
  info            String   @default("")
  speed_string    String   @default("")
  queue_position  Int      @default(0)
  pid             Int?
  job_type        String   @default("train") // 'train', 'caption'
  job_ref         String? // can be used for anything for special jobs, like dataset path for caption jobs

  @@index([status])
  @@index([worker_id])
  @@index([remote_job_id])
  @@index([gpu_ids])
  @@index([job_type])
  @@index([job_ref])

}
